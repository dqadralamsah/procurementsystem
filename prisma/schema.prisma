// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== Role & User =====
model Role {
  id        String   @id @default(uuid()) @db.Uuid
  roleCode  String   @unique @map("role_code")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  email    String @unique
  password String
  name     String
  roleId   String @map("role_id") @db.Uuid
  role     Role   @relation(fields: [roleId], references: [id])

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([roleId])
  @@map("users")
}

// ==========================================
// MASTER DATA
// ==========================================
model Warehouse {
  id            String  @id @default(uuid()) @db.Uuid
  warehouseCode String  @unique @map("warehouse_code")
  name          String
  address       String
  description   String?
  isActive      Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  inventories Inventory[]

  @@map("warehouse")
}

model Supplier {
  id           String  @id @default(uuid()) @db.Uuid
  supplierCode String  @unique @map("supplier_code")
  name         String
  address      String?
  email        String?
  contact      String?
  isActive     Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supplierPrices SupplierPrices[]

  @@map("supplier")
}

model UomCategory {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  uoms Uom[]

  @@map("uom_categories")
}

model Uom {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  categoryId  String      @map("category_id") @db.Uuid
  category    UomCategory @relation(fields: [categoryId], references: [id])
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items          Item[]
  supplierPrices SupplierPrices[]

  @@index([categoryId])
  @@map("uoms")
}

model ItemCategory {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items Item[]

  @@map("item_categories")
}

model Item {
  id          String       @id @default(uuid()) @db.Uuid
  sku         String       @unique @map("sku")
  name        String
  description String?
  categoryId  String       @map("category_id") @db.Uuid
  category    ItemCategory @relation(fields: [categoryId], references: [id])
  uomId       String       @map("uom_id") @db.Uuid
  uom         Uom          @relation(fields: [uomId], references: [id])
  isActive    Boolean      @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supplierPrices SupplierPrices[]
  inventories    Inventory[]

  @@index([sku, categoryId, uomId])
  @@map("items")
}

model SupplierPrices {
  id              String    @id @default(uuid()) @db.Uuid
  supplierId      String    @map("supplier_id") @db.Uuid
  supplier        Supplier  @relation(fields: [supplierId], references: [id])
  itemId          String    @map("item_id") @db.Uuid
  item            Item      @relation(fields: [itemId], references: [id])
  price           Decimal   @default(0) @db.Decimal(18, 4)
  uomId           String    @map("uom_id") @db.Uuid
  uom             Uom       @relation(fields: [uomId], references: [id])
  conversionRatio Decimal   @map("conversion_ratio") @db.Decimal(18, 4)
  minimumOrder    Decimal   @map("minimum_order") @db.Decimal(18, 4)
  effectiveDate   DateTime  @map("effective_date")
  endDate         DateTime? @map("end_date")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([supplierId, itemId, effectiveDate])
  @@index([supplierId, itemId])
  @@map("supplier_prices")
}

model Inventory {
  id           String    @id @default(uuid()) @db.Uuid
  warehouseId  String    @map("warehouse_id") @db.Uuid
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  itemId       String    @map("item_id") @db.Uuid
  item         Item      @relation(fields: [itemId], references: [id])
  stockStatus  String    @default("IN_STOCK") @map("stock_status")
  quantity     Decimal   @default(0) @db.Decimal(18, 4)
  reorderPoint Decimal   @default(0) @map("reorder_point") @db.Decimal(18, 4)
  minimumStock Decimal   @default(0) @map("minimum_stock") @db.Decimal(18, 4)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([itemId, warehouseId])
  @@index([itemId, warehouseId, stockStatus])
  @@map("inventory")
}
